<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Dandelion Estética</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400;1,600&family=Jost:wght@300;400;500&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
:root {
  --cream: #e4e2dd;
  --rose: #cb9398;
  --rose-dark: #b07a80;
  --rose-light: #deb8bc;
  --rose-pale: #f0e4e5;
  --ink: #2e2420;
  --ink-light: #7a6a67;
  --white: #faf9f7;
  --card: #f2f0ec;
  --border: rgba(203,147,152,0.22);
  --shadow: 0 4px 24px rgba(46,36,32,0.08);
  --shadow-lg: 0 12px 48px rgba(46,36,32,0.13);
  --green: #5a8a5a;
  --green-pale: rgba(138,170,138,0.15);
  --red: #a04040;
  --red-pale: rgba(180,80,80,0.1);
  --amber: #8a6a20;
  --amber-pale: rgba(200,170,100,0.1);
}
* { margin:0; padding:0; box-sizing:border-box; }
body { font-family:'DM Sans',sans-serif; background:var(--cream); color:var(--ink); min-height:100vh; overflow-x:hidden; }
.page { display:none; min-height:100vh; }
.page.active { display:flex; flex-direction:column; }
.logo-circle { width:48px; height:48px; border-radius:50%; background:var(--rose-pale); border:1.5px solid rgba(203,147,152,0.35); display:flex; align-items:center; justify-content:center; flex-shrink:0; overflow:hidden; }
.logo-circle-lg { width:90px; height:90px; border-radius:50%; background:var(--rose-pale); border:2px solid rgba(203,147,152,0.4); display:flex; align-items:center; justify-content:center; margin:0 auto 16px; }

/* ============================================================ ADMIN ============================================================ */
#pageAdmin { flex-direction:row; }
.sidebar { width:240px; min-height:100vh; background:var(--ink); display:flex; flex-direction:column; position:fixed; left:0; top:0; bottom:0; z-index:100; }
.sidebar-logo { padding:24px 20px 20px; border-bottom:1px solid rgba(228,226,221,0.1); display:flex; align-items:center; gap:12px; }
.sidebar-logo-text .logo-name { font-family:'Cormorant Garamond',serif; font-size:22px; font-weight:300; letter-spacing:0.1em; color:var(--cream); font-style:italic; line-height:1; }
.sidebar-logo-text .logo-tag { font-size:9px; letter-spacing:0.2em; text-transform:uppercase; color:var(--rose-light); margin-top:2px; }
.logo-circle-sidebar { width:44px; height:44px; border-radius:50%; background:rgba(228,226,221,0.12); border:1.5px solid rgba(203,147,152,0.4); display:flex; align-items:center; justify-content:center; flex-shrink:0; }
.sidebar-nav { flex:1; padding:16px 0; overflow-y:auto; }
.nav-section-label { font-size:9px; letter-spacing:0.25em; text-transform:uppercase; color:rgba(228,226,221,0.35); padding:14px 22px 5px; }
.nav-item { display:flex; align-items:center; gap:11px; padding:10px 22px; cursor:pointer; transition:all 0.2s; border-left:3px solid transparent; color:rgba(228,226,221,0.6); font-size:13px; }
.nav-item:hover { background:rgba(203,147,152,0.12); color:var(--cream); border-left-color:var(--rose); }
.nav-item.active { background:rgba(203,147,152,0.18); color:var(--cream); border-left-color:var(--rose); }
.nav-icon { width:17px; height:17px; flex-shrink:0; }
.portal-link { margin:12px 14px 20px; padding:10px 14px; background:rgba(203,147,152,0.15); border:1px solid rgba(203,147,152,0.3); border-radius:10px; display:flex; align-items:center; gap:8px; cursor:pointer; transition:all 0.2s; color:var(--rose-light); font-size:12px; }
.portal-link:hover { background:rgba(203,147,152,0.25); color:white; }
.admin-main { margin-left:240px; flex:1; display:flex; flex-direction:column; }
.topbar { background:var(--white); border-bottom:1px solid var(--border); padding:0 28px; height:60px; display:flex; align-items:center; justify-content:space-between; position:sticky; top:0; z-index:50; }
.page-title { font-family:'Cormorant Garamond',serif; font-size:20px; font-weight:400; color:var(--ink); }
.topbar-right { display:flex; align-items:center; gap:12px; }
.avatar { width:34px; height:34px; border-radius:50%; background:var(--rose); color:white; font-size:13px; font-weight:500; display:flex; align-items:center; justify-content:center; cursor:pointer; }
.admin-content { padding:28px; flex:1; }
.admin-section { display:none; animation:fadeUp 0.35s ease; }
.admin-section.active { display:block; }
.stats-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:14px; margin-bottom:24px; }
.stat-card { background:var(--white); border-radius:12px; padding:20px 22px; border:1px solid var(--border); box-shadow:var(--shadow); position:relative; overflow:hidden; }
.stat-card::before { content:''; position:absolute; top:0; left:0; right:0; height:3px; background:var(--rose); opacity:0.6; }
.stat-label { font-size:10.5px; letter-spacing:0.15em; text-transform:uppercase; color:var(--ink-light); margin-bottom:6px; }
.stat-value { font-family:'Cormorant Garamond',serif; font-size:34px; font-weight:600; color:var(--ink); line-height:1; }
.stat-sub { font-size:11px; color:var(--rose-dark); margin-top:5px; }
.dash-grid { display:grid; grid-template-columns:2fr 1fr; gap:18px; }
.card { background:var(--white); border-radius:12px; border:1px solid var(--border); box-shadow:var(--shadow); overflow:hidden; }
.card-header { padding:16px 22px; border-bottom:1px solid var(--border); display:flex; align-items:center; justify-content:space-between; }
.card-title { font-family:'Cormorant Garamond',serif; font-size:16px; font-weight:400; color:var(--ink); }
.card-body { padding:18px 22px; }
.appt-list { display:flex; flex-direction:column; gap:9px; }
.appt-item { display:flex; align-items:center; gap:12px; padding:11px 13px; border-radius:8px; border:1px solid var(--border); background:var(--card); transition:box-shadow 0.18s; cursor:pointer; }
.appt-item:hover { box-shadow:var(--shadow); }
.appt-time { font-family:'Cormorant Garamond',serif; font-size:20px; font-weight:400; min-width:50px; text-align:center; line-height:1; }
.appt-time small { display:block; font-size:10px; color:var(--ink-light); font-family:'DM Sans',sans-serif; }
.appt-dot { width:7px; height:7px; border-radius:50%; background:var(--rose); flex-shrink:0; }
.appt-dot.done { background:#8aaa8a; }
.appt-dot.cancelled { background:#c0b0b0; }
.appt-info { flex:1; }
.appt-name { font-weight:500; font-size:13.5px; }
.appt-service { font-size:12px; color:var(--ink-light); }
.appt-prof { font-size:11.5px; color:var(--rose-dark); font-style:italic; }
.badge { display:inline-flex; align-items:center; padding:3px 9px; border-radius:20px; font-size:11px; font-weight:500; }
.badge-confirmed { background:rgba(203,147,152,0.2); color:var(--rose-dark); }
.badge-done { background:rgba(138,170,138,0.2); color:#5a8a5a; }
.badge-cancelled { background:rgba(180,170,170,0.2); color:#8a7a7a; }
.badge-pending { background:rgba(200,170,100,0.2); color:#8a6a20; }
.data-table { width:100%; border-collapse:collapse; }
.data-table th { text-align:left; font-size:10px; letter-spacing:0.15em; text-transform:uppercase; color:var(--ink-light); padding:11px 14px; border-bottom:1.5px solid var(--border); font-weight:500; }
.data-table td { padding:12px 14px; font-size:13px; border-bottom:1px solid rgba(203,147,152,0.1); color:var(--ink); vertical-align:middle; }
.data-table tr:hover td { background:rgba(203,147,152,0.04); }
.data-table tr:last-child td { border-bottom:none; }
.btn { display:inline-flex; align-items:center; gap:7px; padding:8px 16px; border-radius:7px; font-family:'DM Sans',sans-serif; font-size:13px; font-weight:500; cursor:pointer; border:none; transition:all 0.2s; letter-spacing:0.02em; }
.btn-primary { background:var(--rose); color:white; }
.btn-primary:hover { background:var(--rose-dark); box-shadow:0 4px 12px rgba(203,147,152,0.35); }
.btn-outline { background:transparent; color:var(--ink-light); border:1.5px solid var(--border); }
.btn-outline:hover { border-color:var(--rose); color:var(--rose-dark); }
.btn-danger { background:rgba(180,80,80,0.12); color:#a04040; border:1.5px solid rgba(180,80,80,0.25); }
.btn-danger:hover { background:rgba(180,80,80,0.2); }

/* ============================================================ CLIENT PAGE ============================================================ */
#pageClient { font-family:'Jost',sans-serif; background:var(--cream); flex-direction:column; }
#pageClient::before { content:''; position:fixed; inset:0; background: radial-gradient(ellipse 80% 60% at 10% 0%,rgba(203,147,152,0.13) 0%,transparent 60%), radial-gradient(ellipse 60% 50% at 90% 100%,rgba(203,147,152,0.10) 0%,transparent 55%); pointer-events:none; z-index:0; }
.home-btn { position:fixed; top:18px; right:20px; z-index:50; width:42px; height:42px; border-radius:50%; background:var(--white); border:1.5px solid var(--border); box-shadow:var(--shadow); display:flex; align-items:center; justify-content:center; cursor:pointer; transition:all 0.2s; color:var(--ink-light); font-size:18px; }
.home-btn:hover { border-color:var(--rose); color:var(--rose-dark); box-shadow:0 4px 16px rgba(203,147,152,0.25); }
.client-header { text-align:center; padding:36px 20px 16px; position:relative; z-index:1; }
.client-brand-wrap { display:flex; align-items:center; justify-content:center; gap:14px; }
.client-brand-text .brand { font-family:'Cormorant Garamond',serif; font-size:38px; font-weight:300; letter-spacing:0.16em; color:var(--ink); font-style:italic; line-height:1; }
.client-brand-text .brand-sub { font-size:10px; letter-spacing:0.28em; text-transform:uppercase; color:var(--rose); margin-top:3px; }
.progress { display:flex; justify-content:center; align-items:center; padding:20px 20px 28px; position:relative; z-index:1; }
.step { display:flex; flex-direction:column; align-items:center; gap:5px; }
.step-dot { width:30px; height:30px; border-radius:50%; border:2px solid var(--border); background:var(--cream); display:flex; align-items:center; justify-content:center; font-size:11.5px; font-weight:500; color:var(--ink-light); transition:all 0.35s; z-index:2; }
.step.active .step-dot { background:var(--rose); border-color:var(--rose); color:white; box-shadow:0 0 0 5px rgba(203,147,152,0.18); }
.step.done .step-dot { background:var(--rose-dark); border-color:var(--rose-dark); color:white; }
.step-label { font-size:9.5px; letter-spacing:0.12em; text-transform:uppercase; color:var(--ink-light); white-space:nowrap; }
.step.active .step-label { color:var(--rose-dark); font-weight:500; }
.step-line { width:50px; height:1.5px; background:var(--border); margin-bottom:18px; transition:background 0.35s; }
.step-line.done { background:var(--rose); }
.client-container { max-width:640px; margin:0 auto; padding:0 18px 60px; position:relative; z-index:1; }
.c-screen { display:none; animation:fadeUp 0.38s ease; }
.c-screen.active { display:block; }
@keyframes fadeUp { from{opacity:0;transform:translateY(18px)} to{opacity:1;transform:none} }
.c-card { background:var(--white); border-radius:18px; border:1px solid var(--border); box-shadow:0 6px 32px rgba(46,36,32,0.07); overflow:hidden; }
.c-card-title { font-family:'Cormorant Garamond',serif; font-size:23px; font-weight:400; color:var(--ink); text-align:center; padding:26px 28px 5px; font-style:italic; }
.c-card-sub { text-align:center; font-size:13px; color:var(--ink-light); padding:0 28px 22px; line-height:1.5; }
.c-form-body { padding:6px 26px 26px; display:flex; flex-direction:column; gap:13px; }
.c-form-row { display:grid; grid-template-columns:1fr 1fr; gap:13px; }
.c-form-group { display:flex; flex-direction:column; gap:5px; }
.c-form-label { font-size:10px; letter-spacing:0.15em; text-transform:uppercase; color:var(--ink-light); font-weight:500; }
.c-form-input { background:var(--cream); border:1.5px solid rgba(203,147,152,0.25); border-radius:9px; padding:11px 15px; font-family:'Jost',sans-serif; font-size:13.5px; color:var(--ink); outline:none; transition:border-color 0.2s,background 0.2s; }
.c-form-input:focus { border-color:var(--rose); background:white; }
.c-form-input::placeholder { color:var(--rose-light); }
.cat-grid { display:grid; grid-template-columns:repeat(2,1fr); gap:12px; padding:10px 24px 26px; }
.cat-btn { background:var(--card); border:1.5px solid var(--border); border-radius:14px; padding:20px 14px; display:flex; flex-direction:column; align-items:center; gap:9px; cursor:pointer; transition:all 0.22s; text-align:center; position:relative; overflow:hidden; }
.cat-btn::before { content:''; position:absolute; inset:0; background:linear-gradient(135deg,rgba(203,147,152,0.08),transparent); opacity:0; transition:opacity 0.22s; }
.cat-btn:hover { border-color:var(--rose); transform:translateY(-2px); box-shadow:0 8px 24px rgba(203,147,152,0.18); }
.cat-btn:hover::before { opacity:1; }
.cat-icon { width:52px; height:52px; border-radius:50%; background:var(--rose-pale); display:flex; align-items:center; justify-content:center; font-size:24px; transition:transform 0.22s; }
.cat-btn:hover .cat-icon { transform:scale(1.08); }
.cat-name { font-family:'Cormorant Garamond',serif; font-size:16px; font-weight:400; color:var(--ink); font-style:italic; }
.cat-desc { font-size:11px; color:var(--ink-light); line-height:1.4; }
.service-list { display:flex; flex-direction:column; gap:9px; padding:10px 24px 24px; }
.service-item { display:flex; align-items:center; justify-content:space-between; gap:12px; padding:14px 16px; border:1.5px solid var(--border); border-radius:12px; cursor:pointer; transition:all 0.2s; background:var(--card); }
.service-item:hover { border-color:var(--rose); background:var(--rose-pale); transform:translateX(3px); }
.service-item.selected { border-color:var(--rose-dark); background:var(--rose-pale); box-shadow:0 0 0 3px rgba(203,147,152,0.15); }
.service-info { flex:1; }
.service-name { font-weight:500; font-size:14px; margin-bottom:2px; }
.service-meta { font-size:11.5px; color:var(--ink-light); }
.service-price { font-family:'Cormorant Garamond',serif; font-size:20px; color:var(--rose-dark); font-weight:600; white-space:nowrap; }
.service-check { width:21px; height:21px; border-radius:50%; border:2px solid var(--border); flex-shrink:0; display:flex; align-items:center; justify-content:center; transition:all 0.18s; font-size:11px; }
.service-item.selected .service-check { background:var(--rose); border-color:var(--rose); color:white; }
/* Multi-service selected bar */
.selected-services-bar { background:var(--rose-pale); border:1px solid rgba(203,147,152,0.3); border-radius:12px; padding:12px 16px; margin:0 24px 12px; display:none; }
.selected-services-bar.visible { display:block; }
.ssb-title { font-size:10px; letter-spacing:0.15em; text-transform:uppercase; color:var(--ink-light); margin-bottom:8px; font-weight:500; }
.ssb-chips { display:flex; flex-wrap:wrap; gap:6px; margin-bottom:8px; }
.ssb-chip { display:inline-flex; align-items:center; gap:5px; background:var(--rose); color:white; border-radius:20px; padding:4px 10px; font-size:11.5px; }
.ssb-chip-remove { cursor:pointer; opacity:0.75; font-size:13px; line-height:1; }
.ssb-chip-remove:hover { opacity:1; }
.ssb-total { font-size:13px; color:var(--ink); font-weight:500; }
.ssb-total span { color:var(--rose-dark); font-family:'Cormorant Garamond',serif; font-size:17px; }
.cal-nav { display:flex; align-items:center; justify-content:space-between; padding:18px 22px 12px; }
.cal-month-title { font-family:'Cormorant Garamond',serif; font-size:21px; font-weight:400; font-style:italic; color:var(--ink); }
.cal-nav-btn { width:32px; height:32px; border-radius:8px; border:1.5px solid var(--border); background:transparent; cursor:pointer; font-size:16px; color:var(--ink-light); display:flex; align-items:center; justify-content:center; transition:all 0.18s; }
.cal-nav-btn:hover { border-color:var(--rose); color:var(--rose-dark); background:var(--rose-pale); }
.cal-grid-wrap { padding:0 16px 4px; }
.cal-weekdays { display:grid; grid-template-columns:repeat(7,1fr); margin-bottom:4px; }
.cal-wd { text-align:center; font-size:10px; letter-spacing:0.08em; text-transform:uppercase; color:var(--ink-light); padding:4px 0; font-weight:500; }
.cal-days { display:grid; grid-template-columns:repeat(7,1fr); gap:3px; }
.cal-day { aspect-ratio:1; border-radius:8px; display:flex; align-items:center; justify-content:center; font-size:13px; cursor:pointer; transition:all 0.18s; position:relative; }
.cal-day.empty { cursor:default; }
.cal-day.past { color:rgba(122,106,103,0.3); cursor:not-allowed; }
.cal-day.available { color:var(--ink); background:var(--card); border:1.5px solid transparent; }
.cal-day.available:hover { background:var(--rose-pale); border-color:var(--rose-light); color:var(--rose-dark); }
.cal-day.selected { background:var(--rose); color:white; font-weight:500; box-shadow:0 4px 10px rgba(203,147,152,0.35); }
.cal-day.today::after { content:''; position:absolute; bottom:3px; left:50%; transform:translateX(-50%); width:4px; height:4px; border-radius:50%; background:var(--rose); }
.cal-day.today.selected::after { background:white; }
.cal-day.blocked { color:rgba(122,106,103,0.25); cursor:not-allowed; background:repeating-linear-gradient(45deg,transparent,transparent 4px,rgba(203,147,152,0.08) 4px,rgba(203,147,152,0.08) 8px); }
.timeslot-section { padding:14px 18px 22px; border-top:1px solid var(--border); }
.timeslot-title { font-size:10.5px; letter-spacing:0.18em; text-transform:uppercase; color:var(--ink-light); margin-bottom:10px; font-weight:500; }
.slots-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:7px; }
.slot { border:1.5px solid var(--border); border-radius:9px; padding:9px 5px; text-align:center; font-size:13px; cursor:pointer; transition:all 0.18s; background:var(--card); }
.slot:hover { border-color:var(--rose); background:var(--rose-pale); color:var(--rose-dark); }
.slot.taken { color:rgba(122,106,103,0.3); cursor:not-allowed; text-decoration:line-through; background:transparent; border-color:rgba(203,147,152,0.1); }
.slot.selected { background:var(--rose); border-color:var(--rose); color:white; box-shadow:0 3px 10px rgba(203,147,152,0.3); }
.summary-box { margin:0 24px 8px; padding:16px 18px; background:var(--rose-pale); border-radius:12px; border:1px solid rgba(203,147,152,0.25); }
.summary-row { display:flex; align-items:flex-start; justify-content:space-between; padding:5px 0; font-size:13px; }
.summary-row+.summary-row { border-top:1px solid rgba(203,147,152,0.15); }
.summary-key { color:var(--ink-light); flex-shrink:0; }
.summary-val { font-weight:500; text-align:right; }
.c-btn-wrap { padding:5px 24px 26px; display:flex; gap:9px; }
.c-btn { flex:1; padding:12px 18px; border-radius:10px; font-family:'Jost',sans-serif; font-size:14px; font-weight:500; letter-spacing:0.03em; cursor:pointer; border:none; transition:all 0.22s; }
.c-btn-back { background:transparent; border:1.5px solid var(--border); color:var(--ink-light); flex:0 0 auto; padding:12px 16px; }
.c-btn-back:hover { border-color:var(--rose); color:var(--rose-dark); }
.c-btn-primary { background:var(--rose); color:white; box-shadow:0 4px 16px rgba(203,147,152,0.3); }
.c-btn-primary:hover { background:var(--rose-dark); transform:translateY(-1px); }
.c-btn-primary:disabled { background:var(--rose-light); cursor:not-allowed; transform:none; box-shadow:none; }
.c-btn-danger { background:rgba(180,80,80,0.12); color:#a04040; border:1.5px solid rgba(180,80,80,0.25); flex:none; padding:12px 16px; border-radius:10px; font-family:'Jost',sans-serif; font-size:13px; cursor:pointer; transition:all 0.2s; }
.c-btn-danger:hover { background:rgba(180,80,80,0.2); }
.c-back-link { display:flex; align-items:center; gap:5px; color:var(--ink-light); font-size:12.5px; cursor:pointer; margin-bottom:14px; transition:color 0.18s; width:fit-content; }
.c-back-link:hover { color:var(--rose-dark); }
.pill { display:inline-flex; align-items:center; gap:5px; background:var(--rose-pale); color:var(--rose-dark); border-radius:20px; padding:4px 12px; font-size:11px; font-weight:500; margin:0 24px 14px; flex-wrap:wrap; }
.success-screen { text-align:center; padding:44px 26px 38px; }
.success-icon { width:76px; height:76px; border-radius:50%; background:var(--rose-pale); display:flex; align-items:center; justify-content:center; font-size:36px; margin:0 auto 18px; animation:popIn 0.5s cubic-bezier(0.34,1.56,0.64,1); }
@keyframes popIn { from{transform:scale(0);opacity:0} to{transform:scale(1);opacity:1} }
.success-title { font-family:'Cormorant Garamond',serif; font-size:28px; font-weight:400; font-style:italic; color:var(--ink); margin-bottom:9px; }
.success-text { font-size:13.5px; color:var(--ink-light); line-height:1.6; margin-bottom:20px; }
.notif-badge { display:inline-flex; align-items:center; gap:7px; background:var(--rose-pale); border:1px solid rgba(203,147,152,0.3); border-radius:20px; padding:7px 16px; font-size:12px; color:var(--rose-dark); margin-bottom:24px; }
.confirm-card { background:var(--card); border-radius:14px; padding:18px; text-align:left; margin-bottom:22px; border:1px solid var(--border); }
.confirm-row { display:flex; align-items:flex-start; gap:9px; padding:7px 0; font-size:13px; }
.confirm-row+.confirm-row { border-top:1px solid var(--border); }
.confirm-icon { font-size:16px; flex-shrink:0; }
